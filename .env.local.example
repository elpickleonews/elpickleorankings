# Firecrawl — get your key at https://firecrawl.dev
FIRECRAWL_API_KEY=

# Vercel Blob — add the Blob integration in your Vercel project dashboard, then copy the token
BLOB_READ_WRITE_TOKEN=

# Cron security — set any random string here and in Vercel env vars
CRON_SECRET=

# Google Analytics 4 — Measurement ID from analytics.google.com (e.g. G-XXXXXXXXXX)
# Must be NEXT_PUBLIC_ because the GA component reads it client-side
NEXT_PUBLIC_GA_MEASUREMENT_ID=
